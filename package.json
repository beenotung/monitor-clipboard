{
  "name": "monitor-clipboard",
  "version": "1.1.0",
  "type": "commonjs",
  "description": "A CLI that watches your clipboard and saves each new copy to a file. Useful for capturing chat snippets, code blocks, or any copied text over time.",
  "keywords": [
    "clipboard",
    "monitor",
    "cli",
    "watcher",
    "xclip",
    "linux",
    "copy",
    "paste",
    "file-saver",
    "typescript",
    "logging"
  ],
  "author": "Beeno Tung <aabbcc1241@yahoo.com.hk> (https://beeno-tung.surge.sh)",
  "license": "BSD-2-Clause",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/beenotung/monitor-clipboard.git"
  },
  "homepage": "https://github.com/beenotung/monitor-clipboard#readme",
  "bugs": {
    "url": "https://github.com/beenotung/monitor-clipboard/issues"
  },
  "main": "dist/core.js",
  "types": "dist/core.d.ts",
  "bin": {
    "monitor-clipboard": "bin.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "start": "ts-node src/cli.ts",
    "test": "tsc --noEmit",
    "clean": "rimraf dist",
    "build": "rimraf dist && tsc -p . && rimraf dist/tsconfig.tsbuildinfo dist/*.test.d.ts dist/*.test.js dist/*.spec.d.ts dist/*.spec.js",
    "tsc": "tsc -p .",
    "dev": "tsc -p . --watch"
  },
  "devDependencies": {
    "@types/node": "^24.12.0",
    "rimraf": "^6.1.3",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3"
  }
}
